# ================================
# lom 联盟 · 环境变量
# 复制为 .env 并填入真实值
# ================================

# CORS
CORS_ORIGIN=http://localhost:5173

# 数据库
DB_PASSWORD=你的密码
DB_NAME=lom
DATABASE_URL=mysql://root:你的密码@localhost:3306/lom

# JWT（生成：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"）
JWT_SECRET=你的JWT密钥
JWT_EXPIRATION=86400

# 服务器
PORT=3000

# GitHub 用户名（仅服务器 Docker 部署需要）
GH_USER=lingyunmo
