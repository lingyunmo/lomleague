generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int          @id @default(autoincrement())
  username          String       @unique
  password          String
  avatar            String       @default("/default-avatar.png")
  last_login_region Json?
  email             String       @unique
  gold_coins        Int          @default(0)
  is_admin          Boolean      @default(false)
  last_checkin_date DateTime?
  checkin_streak    Int          @default(0)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  forumPosts    ForumPost[]
  forumReplies  ForumReply[]
  Article       Article[]
  likes         Like[]
  notifications Notification[]

  @@index([username])
  @@index([email])
}

model ForumPost {
  id          Int          @id @default(autoincrement())
  userId      Int
  title       String       @default("未命名帖子")
  content     String       @db.Text
  attachments Json?
  region      String?      @default("未知")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies     ForumReply[]

  @@index([userId])
  @@index([updatedAt])
}

model ForumReply {
  id          Int        @id @default(autoincrement())
  postId      Int
  userId      Int
  content     String     @db.Text
  attachments Json?
  region      String?    @default("未知")
  createdAt   DateTime   @default(now())
  post        ForumPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String    @default("未命名文章")
  content     String    @db.Text
  attachments Json?
  region      String?   @default("未知")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([updatedAt])
}

model Like {
  id         Int      @id @default(autoincrement())
  userId     Int
  entityType String
  entityId   Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([entityType, entityId])
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String
  content    String
  entityType String?
  entityId   Int?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}
