{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["*.js", "routes/**/*.js", "services/**/*.js", "dao/**/*.js", "middleware/**/*.js", "utils/**/*.js"],
  "exclude": ["node_modules", "upload", "logs", "public"]
}
